<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyFirstAvaloniaApp.App"
             xmlns:local="using:MyFirstAvaloniaApp"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        
        <!-- Подключаем обе темы статически -->
        <StyleInclude Source="avares://MyFirstAvaloniaApp/Themes/LightTheme.axaml" />
        <StyleInclude Source="avares://MyFirstAvaloniaApp/Themes/DarkTheme.axaml" />
    </Application.Styles>
    
    <!-- Убираем Application.Resources или оставляем пустыми -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>