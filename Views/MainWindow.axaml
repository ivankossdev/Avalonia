<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyFirstAvaloniaApp.ViewModels"
        x:Class="MyFirstAvaloniaApp.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Avalonia Demo"
        Width="1000"
        Height="400">

    <!-- <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext> -->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Левая колонка: кнопки и лог -->
        <DockPanel Grid.Column="0" Margin="10">
            <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,10">
                <Button Content="Кнопка 1"
                        Command="{Binding Button1Command}"
                        Margin="5"
                        Padding="10,5"/>
                <Button Content="Кнопка 2"
                        Command="{Binding Button2Command}"
                        Margin="5"
                        Padding="10,5"/>
                <Button Content="Очистить лог"
                        Command="{Binding ClearCommand}"
                        Margin="5"
                        Padding="10,5"/>
            </StackPanel>

            <TextBox Text="{Binding LogText}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Margin="0"/>
        </DockPanel>

        <!-- Вертикальный разделитель -->
        <Rectangle Grid.Column="1"
                   Width="1"
                   Fill="Gray"
                   Margin="0,10"
                   HorizontalAlignment="Center"/>

        <!-- Правая колонка: асинхронный пример -->
        <StackPanel Grid.Column="2"
                    Orientation="Vertical"
                    Margin="10">
            <TextBlock Text="Асинхронная загрузка:" FontWeight="Bold" Margin="0,5"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Button Content="Загрузить данные"
                        Command="{Binding LoadDataCommand}"
                        Margin="0,0,10,0"
                        Padding="10,5"/>
                
                <Button Content="Отмена"
                        Command="{Binding CancelCommand}"
                        Padding="10,5"/>
                
                <!-- Индикатор загрузки -->
                <ProgressBar IsIndeterminate="True"
                             Width="100"
                             Height="15"
                             IsVisible="{Binding IsLoading}"
                             Margin="10,0"/>
            </StackPanel>

            <!-- Результат загрузки -->
            <TextBox Text="{Binding LoadedData}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     Margin="0,5"
                     Height="60"/>
        </StackPanel>
    </Grid>
</Window>