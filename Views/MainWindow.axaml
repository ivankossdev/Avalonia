<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyFirstAvaloniaApp.ViewModels"
        x:Class="MyFirstAvaloniaApp.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Заметки"
        Width="800"
        Height="400">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Левая колонка: пустая (можно удалить, если не нужна) -->
        <DockPanel Grid.Column="0" Margin="10">
            <!-- Здесь можно разместить что-то ещё, но оставим пустым -->
            <TextBlock Text="Левая колонка (можно использовать для доп. информации)" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </DockPanel>

        <!-- Вертикальный разделитель -->
        <Rectangle Grid.Column="1"
                   Width="1"
                   Fill="Gray"
                   Margin="0,10"
                   HorizontalAlignment="Center"/>

        <!-- Правая колонка: заметки -->
        <StackPanel Grid.Column="2"
                    Orientation="Vertical"
                    Margin="10">
            <TextBlock Text="Заметки:" FontWeight="Bold" Margin="0,5"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Button Content="Добавить"
                        Command="{Binding AddNoteCommand}"
                        Margin="0,0,10,0"
                        Padding="10,5"/>
                <ProgressBar IsIndeterminate="True"
                             Width="100"
                             Height="15"
                             IsVisible="{Binding IsLoading}"
                             Margin="10,0"/>
            </StackPanel>

            <!-- Список заметок -->
            <ListBox ItemsSource="{Binding Notes}"
                     SelectedItem="{Binding SelectedNote}"
                     Height="200"
                     Margin="0,5">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Кнопки для выбранной заметки -->
            <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Center">
                <Button Content="Редактировать"
                        Command="{Binding EditNoteCommand}"
                        CommandParameter="{Binding SelectedNote}"
                        Margin="0,0,10,0"
                        Padding="10,5"/>
                <Button Content="Удалить"
                        Command="{Binding DeleteNoteCommand}"
                        CommandParameter="{Binding SelectedNote}"
                        Padding="10,5"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>