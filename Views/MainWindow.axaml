<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyFirstAvaloniaApp.ViewModels"
        x:Class="MyFirstAvaloniaApp.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Заметки"
        Width="1000"
        Height="400">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Левая колонка: детали выбранной заметки -->
        <DockPanel Grid.Column="0" Margin="10">
            <TextBlock DockPanel.Dock="Top" Text="Детали заметки:" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <StackPanel>
                <TextBlock Text="Заголовок:" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SelectedNote?.Title}" Margin="0,0,0,10"/>
                
                <TextBlock Text="Содержание:" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SelectedNote?.Content}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                
                <TextBlock Text="Дата создания:" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SelectedNote?.CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" Margin="0,0,0,10"/>
            </StackPanel>
        </DockPanel>

        <!-- Вертикальный разделитель -->
        <Rectangle Grid.Column="1"
                   Width="1"
                   Fill="Gray"
                   Margin="0,10"
                   HorizontalAlignment="Center"/>

        <!-- Правая колонка: список заметок -->
        <StackPanel Grid.Column="2"
                    Orientation="Vertical"
                    Margin="10">
            <TextBlock Text="Заметки:" FontWeight="Bold" Margin="0,5"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Button Content="Добавить"
                        Command="{Binding AddNoteCommand}"
                        Margin="0,0,10,0"
                        Padding="10,5"/>
                <Button Content="Экспорт" Command="{Binding ExportNotesAsync}" Margin="0,0,10,0" Padding="10,5"/>
                <Button Content="Импорт" Command="{Binding ImportNotesAsync}" Padding="10,5"/>

                <ProgressBar IsIndeterminate="True"
                             Width="100"
                             Height="15"
                             IsVisible="{Binding IsLoading}"
                             Margin="10,0"/>
            </StackPanel>


            <ListBox ItemsSource="{Binding Notes}"
                     SelectedItem="{Binding SelectedNote}"
                     Height="200"
                     Margin="0,5">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Center">
                <Button Content="Редактировать"
                        Command="{Binding EditNoteCommand}"
                        CommandParameter="{Binding SelectedNote}"
                        Margin="0,0,10,0"
                        Padding="10,5"/>
                <Button Content="Удалить"
                        Command="{Binding DeleteNoteCommand}"
                        CommandParameter="{Binding SelectedNote}"
                        Padding="10,5"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>